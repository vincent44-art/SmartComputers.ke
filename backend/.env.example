# Flask
FLASK_ENV=development
SECRET_KEY=change-me-in-production
JWT_SECRET_KEY=change-me-in-production

# Database (defaults to local SQLite when unset)
# DATABASE_URL=postgresql://smartcomputers:smartcomputers@localhost:5432/smartcomputers

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000

# Redis / Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Email (Flask-Mail)
MAIL_SERVER=smtp.example.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=SmartComputers.ke <no-reply@smartcomputers.ke>

# Cloudinary (media storage)
CLOUDINARY_URL=

# Payments — Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Payments — M-Pesa Daraja
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=
MPESA_CALLBACK_URL=

# Payments — PayPal
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox
